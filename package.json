{
  "name": "yaac",
  "version": "0.0.1",
  "description": "Agent sandbox manager",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "yaac": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp -r dockerfiles podman dist/",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit && eslint .",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:e2e": "vitest run test/e2e",
    "test:watch": "vitest",
    "postinstall": "./setup-git.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "2.1.111",
    "@openai/codex": "0.121.0",
    "commander": "14.0.3",
    "dockerode": "4.0.10",
    "simple-git": "3.35.2",
    "smol-toml": "1.6.1",
    "tar-stream": "3.1.8"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/dockerode": "4.0.1",
    "@types/node": "25.5.2",
    "@types/node-forge": "1.3.14",
    "@types/tar-stream": "3.1.4",
    "eslint": "10.2.0",
    "globals": "17.4.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.3"
  }
}
