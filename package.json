{
  "name": "yaac",
  "version": "0.0.1",
  "description": "Agent sandbox manager",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "yaac": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp -r dockerfiles podman dist/ && tsx scripts/write-build-id.ts",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.frontend.json && eslint .",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:e2e": "vitest run test/e2e",
    "test:watch": "vitest",
    "frontend:dev": "vite",
    "frontend:build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "postinstall": "./setup-git.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "2.1.111",
    "@hono/node-server": "1.19.14",
    "@hono/zod-validator": "0.7.6",
    "@openai/codex": "0.121.0",
    "@tauri-apps/api": "2.10.1",
    "commander": "14.0.3",
    "dockerode": "4.0.10",
    "hono": "4.12.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "simple-git": "3.35.2",
    "smol-toml": "1.6.1",
    "tar-stream": "3.1.8",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.10.0",
    "@tauri-apps/cli": "2.10.1",
    "@types/dockerode": "4.0.1",
    "@types/node": "25.5.2",
    "@types/node-forge": "1.3.14",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@types/tar-stream": "3.1.4",
    "@vitejs/plugin-react": "4.6.0",
    "eslint": "10.2.0",
    "globals": "17.4.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "7.0.4",
    "vitest": "4.1.3"
  }
}
