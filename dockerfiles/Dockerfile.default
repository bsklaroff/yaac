FROM docker.io/ubuntu:24.04

ARG SSL_CERT_FILE
RUN apt-get update && apt-get install -y --no-install-recommends \
    at-spi2-core build-essential ca-certificates catatonit curl dbus-x11 \
    file git less libayatana-appindicator3-dev librsvg2-dev libssl-dev \
    libwebkit2gtk-4.1-dev libxdo-dev locales netcat-openbsd novnc podman \
    python3 python3-websockify socat sudo tmux wget x11vnc xauth xvfb \
    xz-utils zsh && \
    sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen && locale-gen && update-locale LANG=en_US.UTF-8 && \
    if [ -n "$SSL_CERT_FILE" ] && [ -f "$SSL_CERT_FILE" ]; then \
      cp "$SSL_CERT_FILE" /usr/local/share/ca-certificates/proxy-ca.crt && update-ca-certificates; \
    fi && \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      -o /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] \
      https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && apt-get install -y --no-install-recommends gh && \
    rm -rf /var/lib/apt/lists/*
RUN ARCH="$(dpkg --print-architecture)" && if [ "$ARCH" = "amd64" ]; then ARCH=x64; fi && \
    curl -fsSL "https://nodejs.org/dist/v22.22.2/node-v22.22.2-linux-${ARCH}.tar.xz" | \
    tar -xJ -C /usr/local --strip-components=1
RUN ARCH="$(dpkg --print-architecture)" && \
    curl -fsSL "https://github.com/neovim/neovim/releases/download/v0.10.4/nvim-linux-${ARCH}.tar.gz" | \
    tar -xz -C /usr/local --strip-components=1 && \
    ln -sf /usr/local/bin/nvim /usr/local/bin/vi && \
    ln -sf /usr/local/bin/nvim /usr/local/bin/vim
RUN corepack enable
RUN npm install -g @openai/codex

RUN userdel -r ubuntu 2>/dev/null; useradd -m -s /bin/zsh yaac && \
    echo 'Defaults env_keep += "HTTP_PROXY HTTPS_PROXY http_proxy https_proxy NO_PROXY no_proxy SSL_CERT_FILE NODE_EXTRA_CA_CERTS GIT_SSL_CAINFO"' >> /etc/sudoers && \
    echo 'yaac ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers
USER yaac

RUN ARCH="$(dpkg --print-architecture)" && \
    case "$ARCH" in \
      amd64) TRIPLE="x86_64-unknown-linux-gnu" ;; \
      arm64) TRIPLE="aarch64-unknown-linux-gnu" ;; \
      *) echo "unsupported arch: $ARCH" >&2; exit 1 ;; \
    esac && \
    curl --proto '=https' --tlsv1.2 -fsSL \
      "https://static.rust-lang.org/rustup/dist/${TRIPLE}/rustup-init" \
      -o /tmp/rustup-init && \
    chmod +x /tmp/rustup-init && \
    /tmp/rustup-init -y --no-modify-path --profile minimal && \
    rm /tmp/rustup-init && \
    ~/.cargo/bin/rustup component add rustfmt clippy
RUN curl -fsSL https://claude.ai/install.sh | bash
RUN corepack install -g pnpm@10.33.0 && \
    pnpm config set store-dir /home/yaac/.cached-packages/pnpm-store

ENV LANG=en_US.UTF-8
ENV TERM=xterm-256color
ENV HOME=/home/yaac
ENV PATH="/home/yaac/.local/bin:/home/yaac/.cargo/bin:${PATH}"
ENV EDITOR=nvim
ENV SHELL=/bin/zsh
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
ENV DISPLAY=:0
ENV LIBGL_ALWAYS_SOFTWARE=1

RUN cat <<'EOF' > ~/.zshrc
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory
PS1="%n@${YAAC_SESSION_ID:0:8} %~ $ "
alias ls='ls --color=auto'
alias grep='grep --color=auto'
EOF

WORKDIR /workspace
# catatonit acts as PID 1, reaping zombies (orphaned conmon etc.) and
# forwarding signals.  Without a real init, rootless podman leaks zombie
# conmon processes under PID 1 and eventually hits RLIMIT_NPROC.
ENTRYPOINT ["catatonit", "--", "sleep", "infinity"]
